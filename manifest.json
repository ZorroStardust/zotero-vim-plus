{
  "manifest_version": 2,
  "name": "Zotero Vim Plus",
  "version": "1.4.0",
  "description": "Vim-like keybindings for the Zotero PDF reader. Navigate, scroll, anannotate and note with keyboard shortcuts inspired by Vimium/Vim/LazyVim.",
  "author": "ZorroStardust, Alex Fink(original author)",
  "homepage_url": "https://github.com/ZorroStardust/zotero-vim-plus",
  "icons": {
    "64": "icons/icon-64x64.png",
    "128": "icons/icon-128x128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "zotero-vim-plus@zotero-vim",
      "update_url": "https://raw.githubusercontent.com/ZorroStardust/zotero-vim-plus/main/updates.json"
    }
  },
  "applications": {
    "zotero": {
      "id": "zotero-vim-plus@zotero-vim",
      "update_url": "https://raw.githubusercontent.com/ZorroStardust/zotero-vim-plus/main/updates.json",
      "strict_min_version": "7.999",
      "strict_max_version": "9.*"
    }
  }
}
